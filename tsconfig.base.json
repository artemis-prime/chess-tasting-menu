{
  "compilerOptions": {
    "target": "ES2025",
      // No package emits .d.ts (all noEmit / source-consumed), so declaration
      // output is off — also avoids TS6/declaration portability errors (TS2883).
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "useDefineForClassFields": true // mobx
  }
}