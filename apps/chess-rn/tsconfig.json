{
  // CF:  "extends": "@tsconfig/react-native/tsconfig.json",
  "extends": "../../tsconfig.base",

  "compilerOptions": {
    "allowJs": true,
    "jsx": "react-native",
    "noEmit": true,
      // paths resolve relative to this tsconfig; baseUrl is deprecated in TS 6
    "paths": {
      "~/*": ["./src/*"],
    },
  },
  "include": [
    "app.json",
    "src/"
  ],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
  ],
}
  