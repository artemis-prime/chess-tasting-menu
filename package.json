{
  "name": "@artemis-prime/chess-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "pnpm": ">=8"
  },
  "scripts": {
    "_build:first-time": "pnpm install && pnpm prep:serve",
    "tc:domain": "pnpm --filter @artemis-prime/chess-core tc",
    "build:web": "pnpm --filter @artemis-prime/chess-a-la-web build",
    "tc:web": "pnpm --filter @artemis-prime/chess-a-la-web tc",
    "tc:rn": "pnpm --filter @artemis-prime/chess-react-native tc",
    "prep:web": "pnpm refresh:web && pnpm tc:web",
    "prep:rn": "pnpm refresh:rn",
    "refresh:web": "pnpm clean:web && pnpm install",
    "refresh:rn": "pnpm clean:rn && pnpm install",
    "serve:web": "pnpm --filter @artemis-prime/chess-a-la-web start",
    "serve:rn": "pnpm --filter @artemis-prime/chess-react-native start",
    "deploy:rn": "pnpm --filter @artemis-prime/chess-react-native load",
    "link-assets:rn": "pnpm --filter @artemis-prime/chess-react-native link-assets",
    "clean:domain": "pnpm --filter @artemis-prime/chess-core clean",
    "clean:web": "pnpm --filter @artemis-prime/chess-a-la-web clean",
    "clean:rn": "pnpm --filter @artemis-prime/chess-react-native clean",
    "clean:all": "rm -rf ./node_modules && pnpm clean:domain && pnpm clean:web && pnpm clean:rn"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.2.48"
    }
  }
}
